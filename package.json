  "description": "easy-fm is a Node.js module that allows you to interact with\r a [FileMaker database stored](https://www.claris.com/filemaker/) on\r a [FileMaker server](https://www.claris.com/filemaker/server/). This module interacts with your server using the\r [FileMaker Data API](https://help.claris.com/en/data-api-guide/content/index.html).",
  "files": [
    "./dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && jest",
    "test:coverage": "jest --coverage --testPathIgnorePatterns='/__tests__/database.test.ts$'",
    "test:integration": "npm run build && jest __tests__/database.test.ts --runInBand",
    "test:unit": "jest __tests__/query.test.ts __tests__/CookieJar.test.ts --runInBand",
    "stress:search": "tsx src/bin/stressSearch.ts",
    "docs:build": "typedoc --options ./docs/theme.json"
  },
